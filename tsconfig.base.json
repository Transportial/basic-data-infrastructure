{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["bun-types"],
    "paths": {
      "@transportial/kernel": ["./packages/kernel/src/index.ts"],
      "@transportial/kernel/*": ["./packages/kernel/src/*"],
      "@transportial/contracts": ["./packages/contracts/src/index.ts"],
      "@transportial/contracts/*": ["./packages/contracts/src/*"],
      "@transportial/crypto": ["./packages/crypto/src/index.ts"],
      "@transportial/crypto/*": ["./packages/crypto/src/*"],
      "@transportial/crypto-ca": ["./packages/crypto-ca/src/index.ts"],
      "@transportial/crypto-ca/*": ["./packages/crypto-ca/src/*"],
      "@transportial/identity": ["./packages/identity/src/index.ts"],
      "@transportial/identity/*": ["./packages/identity/src/*"],
      "@transportial/events": ["./packages/events/src/index.ts"],
      "@transportial/events/*": ["./packages/events/src/*"],
      "@transportial/policy": ["./packages/policy/src/index.ts"],
      "@transportial/policy/*": ["./packages/policy/src/*"],
      "@transportial/observability": ["./packages/observability/src/index.ts"],
      "@transportial/observability/*": ["./packages/observability/src/*"],
      "@transportial/config": ["./packages/config/src/index.ts"],
      "@transportial/config/*": ["./packages/config/src/*"],
      "@transportial/testing": ["./packages/testing/src/index.ts"],
      "@transportial/testing/*": ["./packages/testing/src/*"],
      "@transportial/recipe-otm": ["./packages/recipe-otm/src/index.ts"],
      "@transportial/recipe-otm/*": ["./packages/recipe-otm/src/*"],
      "@transportial/recipe-efti": ["./packages/recipe-efti/src/index.ts"],
      "@transportial/recipe-efti/*": ["./packages/recipe-efti/src/*"],
      "@transportial/recipe-fhir-r5": ["./packages/recipe-fhir-r5/src/index.ts"],
      "@transportial/recipe-fhir-r5/*": ["./packages/recipe-fhir-r5/src/*"],
      "@transportial/recipe-mmt-rsm": ["./packages/recipe-mmt-rsm/src/index.ts"],
      "@transportial/recipe-mmt-rsm/*": ["./packages/recipe-mmt-rsm/src/*"],
      "@transportial/recipe-iso20022-pacs008": ["./packages/recipe-iso20022-pacs008/src/index.ts"],
      "@transportial/recipe-iso20022-pacs008/*": ["./packages/recipe-iso20022-pacs008/src/*"],
      "@transportial/asr": ["./apps/asr/src/index.ts"],
      "@transportial/asr/*": ["./apps/asr/src/*"],
      "@transportial/ors": ["./apps/ors/src/index.ts"],
      "@transportial/ors/*": ["./apps/ors/src/*"],
      "@transportial/con": ["./apps/con/src/index.ts"],
      "@transportial/con/*": ["./apps/con/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}

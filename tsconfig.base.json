{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["bun-types"],
    "paths": {
      "@bdi/kernel": ["./packages/kernel/src/index.ts"],
      "@bdi/kernel/*": ["./packages/kernel/src/*"],
      "@bdi/contracts": ["./packages/contracts/src/index.ts"],
      "@bdi/contracts/*": ["./packages/contracts/src/*"],
      "@bdi/crypto": ["./packages/crypto/src/index.ts"],
      "@bdi/crypto/*": ["./packages/crypto/src/*"],
      "@bdi/events": ["./packages/events/src/index.ts"],
      "@bdi/events/*": ["./packages/events/src/*"],
      "@bdi/policy": ["./packages/policy/src/index.ts"],
      "@bdi/policy/*": ["./packages/policy/src/*"],
      "@bdi/observability": ["./packages/observability/src/index.ts"],
      "@bdi/observability/*": ["./packages/observability/src/*"],
      "@bdi/config": ["./packages/config/src/index.ts"],
      "@bdi/config/*": ["./packages/config/src/*"],
      "@bdi/testing": ["./packages/testing/src/index.ts"],
      "@bdi/testing/*": ["./packages/testing/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}

{
  "name": "@bdi/crypto-ca",
  "version": "0.1.0",
  "private": true,
  "description": "ACME v2 (RFC 8555) server primitives: account registration with EAB, order + authorization + challenge state machines, CSR signing against an in-process CA.",
  "license": "EUPL-1.2",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@bdi/kernel": "workspace:*",
    "@bdi/crypto": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}

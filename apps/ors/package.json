{
  "name": "@transportial/ors",
  "version": "0.1.0",
  "description": "BDI Orkestratie Register (ORS) - chain contexts, involvement, BVOD issuance.",
  "license": "LicenseRef-PolyForm-Shield-1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "bdi-ors": "dist/bin.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Transportial/basic-data-infrastructure.git",
    "directory": "apps/ors"
  },
  "scripts": {
    "build": "tsup",
    "dev": "bun run --watch ./src/server.ts",
    "start": "bun run ./src/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@transportial/kernel": "^0.1.0",
    "@transportial/contracts": "^0.1.0",
    "@transportial/config": "^0.1.0",
    "@transportial/crypto": "^0.1.0",
    "@transportial/events": "^0.1.0",
    "@transportial/observability": "^0.1.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "module": "./dist/index.js"
}

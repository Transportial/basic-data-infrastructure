{
  "name": "bdi-kerncomponenten",
  "version": "0.1.0",
  "private": true,
  "description": "BDI Kerncomponenten - Reference implementation for Associatie Register (ASR), Orkestratie Register (ORS) and BDI Connector (CON)",
  "license": "EUPL-1.2",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf apps/*/dist packages/*/dist node_modules/.cache",
    "openapi:generate": "bun run scripts/generate-openapi.ts",
    "docs:build": "bun run scripts/generate-openapi.ts && bun run scripts/build-docs.ts"
  },
  "devDependencies": {
    "@bdi/openapi": "workspace:*",
    "@types/bun": "^1.2.0",
    "marked": "^18.0.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}

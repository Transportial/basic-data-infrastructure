{
  "name": "bdi-kerncomponenten",
  "version": "0.1.0",
  "private": true,
  "description": "BDI Kerncomponenten - Reference implementation for Associatie Register (ASR), Orkestratie Register (ORS) and BDI Connector (CON)",
  "license": "EUPL-1.2",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "bun run --filter='*' typecheck",
    "lint": "bun run --filter='*' lint",
    "clean": "rm -rf apps/*/dist packages/*/dist node_modules/.cache"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
